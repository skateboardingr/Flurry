# PyInstaller build output
build/
dist/
*.spec

# Python build artifacts
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Test / type-check / coverage caches
.pytest_cache/
pytest-cache-files-*/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual envs
.venv/
venv/

# Editor / OS
.vscode/
.idea/
*.code-workspace
.DS_Store
Thumbs.db

# Claude Code — user-local settings only; project-level settings.json is shareable
.claude/settings.local.json

# Flurry runtime/output
flurry.zip
flurry-uploads/
*.flurry.json
eqlog_*.txt

# Icon previews — regenerated by make_icon.py whenever the design changes.
# icon.ico is the artifact PyInstaller actually consumes and is committed.
icon.png
icon_preview.png
